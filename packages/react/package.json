{
    "name": "@universal-i18n/react",
    "version": "3.0.1",
    "description": "Zero-config auto-translation for React, Next.js, and Vite",
    "keywords": [
        "i18n",
        "internationalization",
        "translation",
        "auto-translate",
        "react",
        "nextjs",
        "vite",
        "multilingual",
        "localization",
        "l10n",
        "lingo",
        "dom-translation",
        "zero-config",
        "automatic-translation",
        "language-switcher"
    ],
    "author": "Rohit Rawat",
    "repository": {
        "type": "git",
        "url": "https://github.com/rohit27-02/universal-i18n"
    },
    "homepage": "https://github.com/rohit27-02/universal-i18n#readme",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./server": {
            "types": "./dist/server.d.ts",
            "import": "./dist/server.mjs",
            "require": "./dist/server.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "clean": "rimraf dist",
        "dev": "tsup --watch"
    },
    "dependencies": {},
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0"
    },
    "peerDependenciesMeta": {
        "next": {
            "optional": true
        }
    },
    "license": "MIT"
}